# >>> ROS / Colcon workspace >>>

# Build artifacts
build/
install/
log/

# Colcon metadata
.colcon/
.colcon_install_layout
.built_by

# Marker files (don’t accidentally commit these)
COLCON_IGNORE

# Python cache
**/__pycache__/
**/*.py[cod]

# Python package metadata
**/*.egg-info/
dist/

# setup scripts generated by colcon
local_setup.*
*_setup.*

# >>> Editor / OS files >>>

# VSCode
.vscode/

# macOS
.DS_Store

# Windows
Thumbs.db

# Vim swap files
*.swp

src/human_motion_tracker/human_motion_tracker/logs
src/human_motion_tracker/human_motion_tracker/screenshots
